# Anthropic API
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Model tiers (optional — defaults shown below)
# ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001      # classification, simple tasks
# ANTHROPIC_MODEL_STANDARD=claude-sonnet-4-20250514    # complex analysis, drafting

# ChromaDB (optional, defaults to local)
CHROMA_PERSIST_DIR=./chroma_data

# Log level
LOG_LEVEL=INFO
